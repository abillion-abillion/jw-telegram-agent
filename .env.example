# ⚠️ 이 파일은 .gitignore에 추가하세요. 절대 GitHub에 올리지 마세요.

# Telegram Bot Token (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=여기에_봇_토큰_입력

# 진우님 개인 Telegram Chat ID (허용된 사용자만 접근)
# 확인 방법: @userinfobot 에 메시지 보내면 알려줌
ALLOWED_CHAT_ID=여기에_chat_id_숫자_입력

# Anthropic API Key
ANTHROPIC_API_KEY=여기에_claude_api_키_입력

# Railway 배포 후 발급되는 URL (예: https://jw-agent.up.railway.app)
WEBHOOK_URL=여기에_railway_url_입력
